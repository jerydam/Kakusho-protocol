{
  "name": "@trustid/zk-kyc-sdk",
  "version": "0.1.0",
  "description": "Client-side ZK KYC SDK for TrustID — generates Groth16 proofs in-browser, no PII ever leaves the device.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external snarkjs tesseract.js @mediapipe/tasks-vision",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "snarkjs": ">=0.7.0",
    "tesseract.js": ">=5.0.0",
    "@mediapipe/tasks-vision": ">=0.10.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0"
  },
  "keywords": ["zk", "kyc", "groth16", "stellar", "soroban", "identity", "zk-snark"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/zk-kyc-protocol"
  }
}