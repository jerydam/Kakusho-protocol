<!--
  Merge into android/app/src/main/AndroidManifest.xml (generated by
  `npx react-native init`).
-->

<!-- 1. Add as a sibling of <application>, inside <manifest> -->
<uses-permission android:name="android.permission.NFC" />
<uses-feature android:name="android.hardware.nfc" android:required="false" />

<!--
  2. Add as an ADDITIONAL <intent-filter> inside the main <activity> — the
  one that already has the MAIN/LAUNCHER intent-filter. Do not replace the
  existing one; this is a second intent-filter on the same activity.

  android:autoVerify="true" is what makes this an Android App Link rather
  than a plain deep link — it tells Android to verify ownership of the
  domain via assetlinks.json (see well-known/assetlinks.json) before
  routing the link straight to the app instead of a disambiguation dialog
  or the browser.
-->
<intent-filter android:autoVerify="true">
    <action android:name="android.intent.action.VIEW" />
    <category android:name="android.intent.category.DEFAULT" />
    <category android:name="android.intent.category.BROWSABLE" />
    <data
        android:scheme="https"
        android:host="kakusho-protocol.vercel.app"
        android:pathPrefix="/verify/mobile" />
</intent-filter>
